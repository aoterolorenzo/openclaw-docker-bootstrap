# OpenClaw classroom — environment variables
# Copy this file to `.env` (the setup.sh does it for you on first run).
# Values referenced by docker-compose.yml + docker-compose.override.yml.

# -----------------------------------------------------------------------------
# Image (derived from alpine/openclaw via the local Dockerfile)
# -----------------------------------------------------------------------------
OPENCLAW_IMAGE=openclaw-with-deps:local

# -----------------------------------------------------------------------------
# Host bind-mount paths (relative to this file). All your config and skills
# live here on the host filesystem, editable from any file explorer.
# -----------------------------------------------------------------------------
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./openclaw-workspace

# -----------------------------------------------------------------------------
# Gateway auth token. Leave blank — setup.sh fills it with a unique
# `openssl rand -hex 32` value the first time you run it. Do not share or
# commit your filled .env.
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# Networking (defaults are fine for the classroom)
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
# OPENCLAW_TZ=

# -----------------------------------------------------------------------------
# OpenTelemetry export (leave empty unless your class is shipping traces)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=
# OTEL_SEMCONV_STABILITY_OPT_IN=
# OPENCLAW_OTEL_PRELOADED=

# -----------------------------------------------------------------------------
# Claude.ai web cookies (only if you use the Claude-via-cookies provider)
# -----------------------------------------------------------------------------
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
